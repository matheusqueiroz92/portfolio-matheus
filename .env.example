# URL pública do site — usada em metadados, OpenGraph, sitemap, etc.
# Em dev use http://localhost:3000. Em prod, o domínio final.
NEXT_PUBLIC_SITE_URL=https://matheusqueiroz.dev.br

# Resend — envio do formulário de contato (server-side)
# API key gerada em https://resend.com/api-keys. NUNCA prefixe com
# NEXT_PUBLIC_, pois isso exporia a chave no bundle do cliente.
RESEND_API_KEY=
# Remetente. Precisa ser um endereço do domínio verificado no Resend
# (matheusqueiroz.dev.br). Exemplo: contato@matheusqueiroz.dev.br.
RESEND_FROM_EMAIL=contato@matheusqueiroz.dev.br
# Caixa que recebe as mensagens enviadas pelo formulário.
RESEND_TO_EMAIL=gigamatheus@gmail.com
